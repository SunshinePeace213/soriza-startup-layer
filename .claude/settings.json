{
  "autoMemoryEnabled": false,
  "autoMemoryDirectory": "~/soriza-startup-layer/.claude/memory",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "uv run ${CLAUDE_PROJECT_DIR}/.claude/hooks/write_path_guard.py" },
          { "type": "command", "if": "Edit(*STATE.md)|Write(*STATE.md)", "command": "uv run ${CLAUDE_PROJECT_DIR}/.claude/hooks/gates_guard.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "uv run ${CLAUDE_PROJECT_DIR}/.claude/hooks/schema_on_write.py" }
        ]
      },
      {
        "matcher": "Write|Edit|Bash|Task",
        "hooks": [
          { "type": "command", "command": "uv run ${CLAUDE_PROJECT_DIR}/.claude/hooks/run_log.py" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "uv run ${CLAUDE_PROJECT_DIR}/.claude/hooks/stop_guard.py" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume|compact",
        "hooks": [
          { "type": "command", "command": "uv run ${CLAUDE_PROJECT_DIR}/.claude/hooks/resume_inject.py" }
        ]
      }
    ]
  }
}
